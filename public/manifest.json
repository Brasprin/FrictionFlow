{
  "manifest_version": 3,
  "name": "FrictionFlow",
  "version": "1.0",
  "description": "AI-assisted writing recovery extension",
  "key": "",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://docs.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "oauth2": {
    "client_id": "600200227791-gkdbu0b4e587hud31vr5tbte24j09t1n.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/documents.readonly"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "side_panel": {
    "default_path": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/*"],
      "js": ["content.js"]
    }
  ]
}